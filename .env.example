NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
TELEMETRY_API_KEY=dev-telemetry-key
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h
DB_HOST=127.0.0.1
DB_PORT=6543
DB_NAME=safeair
DB_USER=postgres
DB_PASSWORD=postgres
DB_LOGGING=false
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=safeair-api
MQTT_TELEMETRY_TOPIC=safeair/+/telemetry
MQTT_QOS=1
