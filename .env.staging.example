NODE_ENV=production
PORT=10000
API_PREFIX=/api/v1
TELEMETRY_API_KEY=replace-with-strong-telemetry-key
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h
DB_HOST=replace-db-host
DB_PORT=5432
DB_NAME=replace-db-name
DB_USER=replace-db-user
DB_PASSWORD=replace-db-password
DB_LOGGING=false
DB_SYNC_ON_STARTUP=true
MQTT_URL=replace-mqtt-url
MQTT_USERNAME=replace-mqtt-username
MQTT_PASSWORD=replace-mqtt-password
MQTT_CLIENT_ID=safeair-api-staging
MQTT_TELEMETRY_TOPIC=safeair/+/telemetry
MQTT_QOS=1
